# Seashore Examples Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# LLM Provider API Keys
# ============================================

# OpenAI (required for most examples)
OPENAI_API_KEY=your_openai_key_here
# Optional: Custom base URL (for proxy, Azure, or local models)
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude (required for some examples)
ANTHROPIC_API_KEY=your_anthropic_key_here
# Optional: Custom base URL
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (optional)
GEMINI_API_KEY=your_gemini_key_here

# ============================================
# Database Configuration (for data examples)
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/seashore

# Vector database (can be same as DATABASE_URL)
VECTOR_DB_URL=postgresql://user:password@localhost:5432/seashore

# ============================================
# Third-Party Services (for specific examples)
# ============================================

# Serper.dev API key (for web search tool)
SERPER_API_KEY=your_serper_key_here

# Firecrawl API key (for web scraping tool)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# ============================================
# MCP Server Configuration (for MCP examples)
# ============================================

# Example: filesystem MCP server
FILESYSTEM_MCP_SERVER=npx -y @modelcontextprotocol/server-filesystem /tmp

# ============================================
# Optional: Logging and Debug
# ============================================

# Enable debug logging
DEBUG=seashore:*

# Log level (error, warn, info, debug)
LOG_LEVEL=info
